{
  "manifest_version": 3,
  "name": "Utility Energy Downloader",
  "version": "0.1.0",
  "description": "Local-only downloader for meter usage time-series data from a supported electric utility account.",
  "minimum_chrome_version": "102",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "action": {
    "default_title": "Utility Energy Downloader",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://offpeakadvisor.com/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://csapps.rockymountainpower.net/secure/my-account/energy-usage*"
      ],
      "js": [
        "src/page-hook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://csapps.rockymountainpower.net/secure/my-account/energy-usage*"
      ],
      "js": [
        "src/time.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
